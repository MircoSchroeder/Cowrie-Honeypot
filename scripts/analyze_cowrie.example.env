# analyze_cowrie.py environment configuration
# Copy to analyze_cowrie.env and fill in your values.

# Cowrie JSON log file (not the directory)
COWRIE_LOG=/path/to/cowrie/var/log/cowrie/cowrie.json

# Telegram bot
TG_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TG_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# AbuseIPDB (https://www.abuseipdb.com/account/api)
ABUSEIPDB_KEY=YOUR_ABUSEIPDB_API_KEY

# VirusTotal v3 API (https://www.virustotal.com/gui/my-apikey)
# Leave blank to disable VT lookups.
VIRUSTOTAL_KEY=YOUR_VIRUSTOTAL_API_KEY

# Suppress alerts for IPs with AbuseIPDB score >= this value.
# 101 = report everything (default). 50 = stricter.
ABUSEIPDB_SCORE_THRESHOLD=101

# Persistent IP reputation cache
IP_CACHE_FILE=/var/lib/analyze_cowrie/ip_cache.json

# Path to Inspector Gadget SQLite DB for cluster filtering.
# If the DB doesn't exist, the filter is disabled automatically.
IG_DB_PATH=/opt/inspector_gadget/inspector_gadget.db
