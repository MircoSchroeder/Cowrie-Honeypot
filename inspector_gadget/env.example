# Inspector Gadget environment configuration
# Copy to .env and source it before starting, or load it via systemd EnvironmentFile=

# --- Telegram (required) ---
IG_TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
IG_TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- Cowrie log directory (required) ---
IG_COWRIE_LOG_DIR=/path/to/cowrie/var/log/cowrie/

# --- Database (optional, default shown) ---
IG_DB_PATH=/opt/inspector_gadget/inspector_gadget.db

# --- Ingester tuning (optional) ---
IG_INGEST_INTERVAL=30
IG_IP_LINK_WINDOW=259200
IG_MIN_CMD_SEQ=3

# --- Logging ---
IG_LOG_LEVEL=INFO
IG_LOG_FILE=/opt/inspector_gadget/inspector_gadget.log
